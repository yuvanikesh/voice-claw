# ── API Keys ── (Required)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
SARVAM_API_KEY=""
FIRECRAWL_API_KEY=""

# ── App URL ──
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_API_URL: Set this to point VoiceClaw to a custom backend API.
# If omitted or empty, the app will request its own Express backend at /api/*.
NEXT_PUBLIC_API_URL=""

# AI_API_KEY: Optional. If present, the onboarding chat uses the configured LLM provider.
AI_API_KEY=""
AI_MODEL=""

# ── Infrastructure ──
DATABASE_URL="sqlite:///./voiceclaw.db"
CHROMA_PERSIST_DIR="./chroma_db"
UPLOAD_DIR="./uploads"
PORT=8000

# ── Sarvam API (all optional — sensible defaults in config.py) ──
# SARVAM_BASE_URL="https://api.sarvam.ai"
# SARVAM_STT_MODEL="saarika:v2"
# SARVAM_TTS_MODEL="bulbul:v2"
# SARVAM_TTS_SPEAKER="meera"
# SARVAM_TRANSLATE_MODEL="mayura:v1"
# SARVAM_CHAT_MODEL="sarvam-m"
# SARVAM_API_TIMEOUT=30.0
# SARVAM_LID_TIMEOUT=15.0
# SARVAM_DOC_TIMEOUT=60.0
# SARVAM_DOC_POLL_INTERVAL=3.0
# SARVAM_DOC_MAX_POLLS=60
# SARVAM_DOC_OUTPUT_FORMAT="md"
# SARVAM_DOC_PAGE_LIMIT=10

# ── Gemini ──
# GEMINI_MODEL="gemini-2.0-flash"

# ── Embeddings ──
# EMBEDDING_MODEL="all-MiniLM-L6-v2"

# ── Chunking ──
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50

# ── RAG ──
# RAG_TOP_K=4
# RAG_MAX_TOKENS=200
# RAG_TEMPERATURE=0.3
# RAG_HISTORY_LIMIT=4

# ── Language defaults ──
# DEFAULT_LANGUAGE_CODE="en-IN"
# DEFAULT_AUDIO_FORMAT="webm"

# ── Upload limits ──
# MAX_UPLOAD_SIZE_MB=20
